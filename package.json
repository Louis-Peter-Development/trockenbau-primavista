{
  "name": "trockenbau-primavista",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "npm --prefix client install",
    "dev": "npx --yes --package netlify-cli netlify dev",
    "dev:vite": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "lint": "npm --prefix client run lint",
    "test": "node --test \"netlify/functions/_shared/**/*.test.mjs\" && npm --prefix client test",
    "audit": "npm audit --omit=dev && npm --prefix client audit --omit=dev"
  },
  "dependencies": {
    "openai": "^6.33.0"
  }
}
